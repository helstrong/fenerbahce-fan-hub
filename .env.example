# Fenerbahçe Fan Hub — configuration template. Copy to .env for local dev.
#
# The app talks to TheSportsDB through a same-origin proxy so the API key stays
# on the server and is never exposed in the browser bundle.

# --- Server-side secret (NOT VITE_-prefixed → never shipped to the client) ----
# TheSportsDB API key. "123" is the free shared test key (works with no account
# but caps data); a premium key removes the limits.
SPORTSDB_KEY=123

# Optional: upstream base and server port (defaults shown).
# SPORTSDB_UPSTREAM=https://www.thesportsdb.com
# PORT=3000

# --- Public build-time config (VITE_ = bundled into the browser; no secrets) ---

# Set to true only when SPORTSDB_KEY is the free "123" key, so the UI shows the
# free-tier limit notes (top-5 table, ~10-player squad).
VITE_SPORTSDB_FREE_TIER=true

# Set to true to force the bundled sample data instead of live data.
VITE_USE_SAMPLE=

# Optional overrides (defaults shown). Season format is YYYY-YYYY.
VITE_LEAGUE_ID=4339
VITE_SEASON=2025-2026
VITE_TEAM_ID=133807

# Only override if you host the proxy somewhere other than the same origin.
# VITE_SPORTSDB_BASE=/api/sportsdb
