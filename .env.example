# TheSportsDB (https://www.thesportsdb.com/) — the app uses live data by default
# via the free shared test key "123", so NO configuration is required to start.
#
# For higher rate limits and fuller data, become a TheSportsDB Patreon supporter
# to get a personal key and set it below, then restart the dev server.
#
# SECURITY NOTE: VITE_ variables are bundled into the browser build, so any key
# ships to the client. That's fine for local/personal use. For a public deployment,
# proxy requests through a small server function instead of exposing the key.
VITE_SPORTSDB_KEY=123

# Set to true to force the bundled sample data instead of live data.
VITE_USE_SAMPLE=

# Optional overrides (defaults shown). Season format is YYYY-YYYY.
VITE_SPORTSDB_BASE=https://www.thesportsdb.com/api/v1/json
VITE_LEAGUE_ID=4339
VITE_SEASON=2025-2026
VITE_TEAM_ID=133807
