# API-Football (https://www.api-football.com/) — sign up for a free key and paste
# it below, then restart the dev server. With no key the app runs on sample data.
#
# SECURITY NOTE: VITE_ variables are bundled into the browser build, so the key
# ships to the client. That's fine for local/personal use. For a public deployment,
# proxy requests through a small server function instead of exposing the key.
VITE_API_FOOTBALL_KEY=

# Optional overrides (defaults shown).
# Free-tier plans are limited to seasons 2021–2023, so a past season is the default.
# For the current season and live upcoming fixtures you need a paid plan.
VITE_API_FOOTBALL_BASE=https://v3.football.api-sports.io
VITE_LEAGUE_ID=203
VITE_SEASON=2023
VITE_TEAM_ID=611
